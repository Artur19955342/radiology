VITE_DATA_BACKEND=local

# Set VITE_DATA_BACKEND=api when deploying with Vercel Functions.
POSTGRES_URL=

# Server-only. Do not expose this value with a VITE_ prefix.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_MS=14000

# Optional key/model for free-text search. Falls back to DEEPSEEK_API_KEY.
DEEPSEEK_PRO_API_KEY=
DEEPSEEK_PRO_MODEL=deepseek-v4-pro
DEEPSEEK_PRO_TIMEOUT_MS=45000
